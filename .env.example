# ── Web (Next.js) ─────────────────────────────────────────────
# Copy to apps/web/.env.local for local dev

# Mapbox — required for the map UI
# https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your_token_here

# Database — local Docker PostGIS (default from docker-compose.yml)
DATABASE_URL=postgresql://wavefinder:wavefinder@localhost:5432/wavefinder

# ML worker — local FastAPI; on Vercel use a hosted worker URL (Railway, Fly, etc.)
ML_WORKER_URL=http://localhost:8000

# ── Python ML worker (services/ml/.env) ─────────────────────
# DATABASE_URL=postgresql://wavefinder:wavefinder@localhost:5432/wavefinder
# WAVE_FINDER_DATA_DIR=./data
# MODEL_WEIGHTS_DIR=./models

# ── Vercel / production (later) ───────────────────────────────
# DATABASE_URL=postgresql://...@neon.tech/wavefinder  (Neon + PostGIS)
# ML_WORKER_URL=https://your-ml-worker.railway.app
# Do NOT put long-running train/scan on Vercel serverless functions.
